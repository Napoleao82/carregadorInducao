/**
 * Credenciais Wi-Fi (NÃO versionar o ficheiro real).
 *
 * 1. Copie este ficheiro para secrets.h na mesma pasta do sketch:
 *      cp secrets.h.example secrets.h
 * 2. Edite secrets.h com o SSID e a palavra-passe da sua rede.
 * 3. secrets.h está no .gitignore e não deve ser enviado para o Git.
 *
 * PlatformIO (opcional): em vez de secrets.h, pode definir no ambiente e
 * passar no platformio.ini, por exemplo:
 *   build_flags =
 *     '-DWIFI_SSID="${sysenv.WIFI_SSID}"'
 *     '-DWIFI_PASS="${sysenv.WIFI_PASS}"'
 * e exportar WIFI_SSID / WIFI_PASS no terminal antes de compilar.
 * Nesse caso, comente ou remova o #include "secrets.h" no .ino e garanta
 * que as macros existem antes da compilação (ajuste conforme o seu ini).
 */

#ifndef SECRETS_H
#define SECRETS_H

#define WIFI_SSID "nome_da_sua_rede"
#define WIFI_PASS "sua_senha_wifi"

#endif
